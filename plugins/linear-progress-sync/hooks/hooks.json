{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'script=$(ls -td \"$HOME\"/.codex/plugins/cache/*/linear-progress-sync/*/scripts/session_start.py 2>/dev/null | head -n 1); [ -n \"$script\" ] && exec python3 \"$script\" || exit 0'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'script=$(ls -td \"$HOME\"/.codex/plugins/cache/*/linear-progress-sync/*/scripts/pre_tool_use.py 2>/dev/null | head -n 1); [ -n \"$script\" ] && exec python3 \"$script\" || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'script=$(ls -td \"$HOME\"/.codex/plugins/cache/*/linear-progress-sync/*/scripts/post_tool_use.py 2>/dev/null | head -n 1); [ -n \"$script\" ] && exec python3 \"$script\" || exit 0'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'script=$(ls -td \"$HOME\"/.codex/plugins/cache/*/linear-progress-sync/*/scripts/stop_progress.py 2>/dev/null | head -n 1); [ -n \"$script\" ] && exec python3 \"$script\" || exit 0'"
          }
        ]
      }
    ]
  }
}
